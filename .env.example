# Local (Docker): docker compose up -d
# Production: connection string từ Supabase (pooler port 6543 + ?pgbouncer=true)
DATABASE_URL="postgresql://trannano:trannano@localhost:5432/trannano?schema=public"

JWT_SECRET="change-me-to-a-long-random-string"

# Cloudflare R2 (S3-compatible) — bắt buộc trên Vercel production
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# URL public của bucket (r2.dev hoặc custom domain), không có dấu / cuối
# Ví dụ: https://pub-xxxxx.r2.dev  hoặc  https://cdn.trannano.vn
R2_PUBLIC_URL=
# Cùng giá trị R2_PUBLIC_URL — để next/image allow hostname lúc build trên Vercel
NEXT_PUBLIC_R2_PUBLIC_URL=

# Production: https://trannano.vn  |  Local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://trannano.vn
ADMIN_EMAIL=admin@trannano.vn
ADMIN_PASSWORD=admin123456
